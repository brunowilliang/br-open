{
  "expo": {
    "name": "BR Open",
    "slug": "br-open",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bropen",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.brunogarcia.bropen",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0485F7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.brunoidonate.bropen"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0485F7",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 176
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "color": "#0485F7"
        }
      ],
      "expo-font",
      "expo-image",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5acfd14c-2868-454d-80f5-0d83a2222680"
      }
    },
    "owner": "brunowilliang",
    "updates": {
      "url": "https://u.expo.dev/5acfd14c-2868-454d-80f5-0d83a2222680"
    }
  }
}
