{
  "name": "br-open",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "dev": "expo start -c",
    "dev:client": "expo start --dev-client --lan --scheme bropen",
    "prebuild": "expo prebuild -p all --clean",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:ios:dev": "eas build -p ios --profile development --auto-submit --non-interactive",
    "build:ios:prod": "eas build -p ios --profile production --auto-submit --non-interactive",
    "update:ios:dev": "eas update --channel development --platform ios --environment development --non-interactive --message \"Update iOS Dev\"",
    "update:ios:prod": "eas update --channel production --platform ios --environment production --non-interactive --message \"Update iOS Prod\"",
    "build:android:dev": "eas build -p android --profile development --non-interactive",
    "build:android:prod": "eas build -p android --profile production --non-interactive",
    "update:android:dev": "eas update --channel development --platform android --environment development --non-interactive --message \"Update Android Dev\"",
    "update:android:prod": "eas update --channel production --platform android --environment production --non-interactive --message \"Update Android Prod\"",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit && bun run typecheck:convex",
    "codegen": "bunx kitcn codegen",
    "convex:dev": "bunx kitcn dev",
    "typecheck:convex": "tsc --noEmit --project convex/functions/tsconfig.json",
    "check": "ultracite check && bun run typecheck",
    "test": "bun test",
    "test:convex": "bun test convex",
    "fix": "ultracite fix",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@better-auth/expo": "1.6.24",
    "@better-auth/i18n": "1.6.24",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.2.3",
    "@hugeicons/react-native": "^1.0.15",
    "@internationalized/date": "^3.12.0",
    "@internationalized/number": "^3.6.6",
    "@legendapp/list": "^3.3.3",
    "@legendapp/state": "~3.0.0-beta.48",
    "@opentelemetry/api": "1.9.1",
    "@sbaiahmed1/react-native-blur": "^4.7.1",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "5.101.4",
    "@woovi/node-sdk": "^1.3.3",
    "better-auth": "1.6.24",
    "better-styled": "^1.3.2",
    "convex": "1.42.3",
    "expo": "~57.0.8",
    "expo-apple-authentication": "~57.0.1",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.7",
    "expo-dev-client": "~57.0.8",
    "expo-device": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-glass-effect": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.6",
    "expo-image-picker": "~57.0.6",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-network": "~57.0.1",
    "expo-notifications": "~57.0.7",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.9",
    "expo-web-browser": "~57.0.2",
    "heroui-native": "^1.0.6",
    "heroui-native-pro": "~1.0.0-beta.7",
    "hono": "4.12.31",
    "kitcn": "0.15.15",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.82.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-reanimated": "4.5.0",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "resend": "^6.18.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.3",
    "uniwind": "^1.10.0",
    "victory-native": "^41.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/bun": "~1.3.14",
    "@types/react": "~19.2.17",
    "lefthook": "^2.1.10",
    "serve-sim": "0.1.45",
    "typescript": "~7.0.2",
    "ultracite": "7.9.4"
  },
  "trustedDependencies": [
    "heroui-pro",
    "@heroui-pro/react",
    "heroui-native-pro",
    "@shopify/react-native-skia"
  ],
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  }
}
