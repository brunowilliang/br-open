{
  "name": "br-open",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "dev": "expo start -c",
    "dev:client": "expo start --dev-client --lan --scheme bropen",
    "prebuild": "expo prebuild -p all --clean",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:ios:testflight": "eas build -p ios --profile production --auto-submit --non-interactive",
    "update:ios:testflight": "eas update --channel production --platform ios --environment preview --non-interactive --message \"Update iOS\"",
    "build:android:preview": "eas build -p android --profile preview --non-interactive",
    "update:android:preview": "eas update --channel preview --platform android --environment preview --non-interactive --message \"Update Android\"",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit && bun run typecheck:convex",
    "codegen": "bunx kitcn codegen",
    "convex:dev": "bunx kitcn dev",
    "typecheck:convex": "tsc --noEmit --project convex/functions/tsconfig.json",
    "check": "ultracite check && bun run typecheck",
    "test": "bun test",
    "test:convex": "bun test convex",
    "fix": "ultracite fix",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@better-auth/expo": "1.6.9",
    "@better-auth/i18n": "1.6.9",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react-native": "^1.0.13",
    "@internationalized/date": "^3.12.0",
    "@internationalized/number": "^3.6.6",
    "@legendapp/list": "~3.0.0-beta.56",
    "@legendapp/state": "~3.0.0-beta.47",
    "@opentelemetry/api": "1.9.0",
    "@sbaiahmed1/react-native-blur": "^4.6.3",
    "@shopify/react-native-skia": "~2.6.2",
    "@tanstack/react-query": "5.95.2",
    "@woovi/node-sdk": "^1.3.3",
    "better-auth": "1.6.9",
    "better-styled": "^1.3.2",
    "convex": "1.39.1",
    "expo": "~56.0.12",
    "expo-apple-authentication": "~56.0.4",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "heroui-native": "^1.0.4",
    "heroui-native-pro": "~1.0.0-beta.5",
    "hono": "4.12.9",
    "kitcn": "0.15.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.75.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "resend": "^6.17.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "uniwind": "^1.9.0",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "~1.3.14",
    "@types/react": "~19.2.2",
    "lefthook": "^2.1.6",
    "serve-sim": "0.1.41",
    "typescript": "~6.0.3",
    "ultracite": "7.6.3"
  },
  "trustedDependencies": [
    "heroui-pro",
    "@heroui-pro/react",
    "heroui-native-pro",
    "@shopify/react-native-skia"
  ]
}
